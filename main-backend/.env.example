# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-jwt-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
# Dev only: allows /auth/dev-login without Google credentials (never enable in production)
ALLOW_DEV_LOGIN=true

# Microservices
USERS_SERVICE_URL=http://localhost:4001
FAVORITES_SERVICE_URL=http://localhost:4002
INTERNAL_API_TOKEN=change-me-internal-secret

# External API (our MLOps project's production backend)
FIFA_API_URL=https://fifa-backend-production.onrender.com
